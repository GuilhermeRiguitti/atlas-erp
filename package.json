{
  "name": "atlas-users-suite",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant fiscal ERP SaaS with NestJS, Next.js, Prisma, MySQL and iron-session authentication.",
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev:all": "concurrently -n api,web,worker -c blue,green,magenta \"pnpm dev:api\" \"pnpm dev:web\" \"pnpm dev:worker\"",
    "dev:no-worker": "pnpm --parallel --filter api --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter api worker:dev",
    "build": "pnpm -r build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm -r lint",
    "test": "pnpm --filter api test",
    "format": "pnpm -r format",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:push": "pnpm --filter api prisma:push",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:migrate:deploy": "pnpm --filter api prisma:migrate:deploy",
    "db:migrate:reset": "pnpm --filter api prisma:migrate:reset",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:studio": "pnpm --filter api prisma:studio",
    "docker:infra": "docker compose up -d mysql redis",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "dev:up": "docker compose -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:migrate": "docker compose -f docker-compose.dev.yml run --rm migrate",
    "dev:reset": "docker compose -f docker-compose.dev.yml down -v"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.7.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ],
    "ignoredBuiltDependencies": [
      "msgpackr-extract"
    ]
  }
}
