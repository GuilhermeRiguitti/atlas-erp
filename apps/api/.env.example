DATABASE_URL="mysql://atlas:atlas_password@localhost:3306/atlas_users"
PORT=3333
WEB_ORIGIN="http://localhost:3000"
INTERNAL_API_KEY="replace_with_a_long_random_internal_api_key"
ONBOARDING_JWT_SECRET="replace_with_a_long_random_onboarding_secret"
FISCAL_CREDENTIALS_ENCRYPTION_KEY="replace_with_a_long_random_fiscal_credentials_key"
NFEIO_BASE_URL="https://api.nfe.io"
# NFS-e Nacional (Receita Federal / SEFIN). Modo:
#   mock             -> gera resposta fiel ao contrato sem rede nem certificado (demo/portfolio)
#   producao_restrita -> homologacao oficial, exige certificado A1 ICP-Brasil no tenant
#   producao          -> emissao real
NFSE_NACIONAL_MODE="mock"
NFSE_NACIONAL_BASE_URL="https://sefin.producaorestrita.nfse.gov.br/SefinNacional"
REDIS_HOST="localhost"
REDIS_PORT=6379
FISCAL_QUEUE_ATTEMPTS=5
FISCAL_QUEUE_BACKOFF_MS=30000
FISCAL_QUEUE_CONCURRENCY=2
SEED_ADMIN_EMAIL="admin@atlas.dev"
SEED_ADMIN_PASSWORD="change_this_seed_password"
