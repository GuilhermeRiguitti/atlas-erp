generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  RECRUITER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum TenantStatus {
  ACTIVE
  ONBOARDING
  SUSPENDED
}

enum TenantTaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
  MEI
}

enum TenantTitularRole {
  OWNER
  PARTNER
  ACCOUNTANT
  FINANCIAL_MANAGER
}

enum FiscalProvider {
  MOCK
  NFE_IO
}

enum ServiceInvoiceStatus {
  DRAFT
  PROCESSING
  AUTHORIZED
  REJECTED
  CANCELLED
}

enum ClientType {
  INDIVIDUAL
  COMPANY
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  passwordHash          String
  role                  UserRole         @default(MEMBER)
  status                UserStatus       @default(ACTIVE)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  profile               UserProfile?
  tenantTitularities    TenantTitular[]
  createdClients        Client[]         @relation("CreatedClients")
  issuedServiceInvoices ServiceInvoice[] @relation("IssuedServiceInvoices")

  @@index([name])
  @@index([status])
}

model UserProfile {
  id           String   @id @default(cuid())
  headline     String
  bio          String   @db.Text
  location     String
  seniority    String
  skills       String   @db.Text
  availability String
  website      String?
  github       String?
  linkedin     String?
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Tenant {
  id                      String            @id @default(cuid())
  legalName               String
  tradeName               String?
  cnpj                    String            @unique
  status                  TenantStatus      @default(ONBOARDING)
  taxRegime               TenantTaxRegime   @default(SIMPLES_NACIONAL)
  municipalRegistration   String?
  stateRegistration       String?
  cnae                    String?
  serviceTaxCode          String?
  municipalServiceCode    String?
  fiscalProvider          FiscalProvider    @default(MOCK)
  fiscalProviderCompanyId String?
  contactEmail            String
  contactPhone            String?
  addressStreet           String
  addressNumber           String
  addressComplement       String?
  addressNeighborhood     String
  addressCity             String
  addressState            String
  addressCityIbgeCode     String
  addressZipCode          String
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  titulares               TenantTitular[]
  clients                 Client[]
  serviceInvoices         ServiceInvoice[]

  @@index([legalName])
  @@index([status])
  @@index([addressCityIbgeCode])
}

model TenantTitular {
  id                    String            @id @default(cuid())
  tenantId              String
  userId                String
  role                  TenantTitularRole @default(OWNER)
  title                 String?
  ownershipPercentage   Decimal?          @db.Decimal(5, 2)
  isLegalRepresentative Boolean           @default(false)
  canIssueInvoices      Boolean           @default(true)
  joinedAt              DateTime          @default(now())
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
}

model Client {
  id                    String        @id @default(cuid())
  tenantId              String
  createdByUserId       String?
  type                  ClientType    @default(COMPANY)
  status                ClientStatus  @default(ACTIVE)
  name                  String
  tradeName             String?
  document              String
  email                 String?
  phone                 String?
  municipalRegistration String?
  stateRegistration     String?
  addressStreet         String?
  addressNumber         String?
  addressComplement     String?
  addressNeighborhood   String?
  addressCity           String?
  addressState          String?
  addressZipCode        String?
  notes                 String?       @db.Text
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  tenant                Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy             User?         @relation("CreatedClients", fields: [createdByUserId], references: [id], onDelete: SetNull)
  serviceInvoices       ServiceInvoice[]

  @@unique([tenantId, document])
  @@index([tenantId])
  @@index([createdByUserId])
  @@index([name])
  @@index([status])
}

model ServiceInvoice {
  id                   String               @id @default(cuid())
  tenantId             String
  clientId             String?
  issuedByUserId       String?
  status               ServiceInvoiceStatus @default(DRAFT)
  provider             FiscalProvider       @default(MOCK)
  providerExternalId   String?
  verificationCode     String?
  rpsNumber            String?
  serviceDescription   String               @db.Text
  serviceCode          String?
  cnaeCode             String?
  municipalTaxCode     String?
  borrowerName         String
  borrowerDocument     String
  borrowerEmail        String?
  borrowerStreet       String?
  borrowerNumber       String?
  borrowerNeighborhood String?
  borrowerCity         String?
  borrowerState        String?
  borrowerZipCode      String?
  amount               Decimal              @db.Decimal(12, 2)
  deductions           Decimal              @default(0) @db.Decimal(12, 2)
  issRate              Decimal?             @db.Decimal(5, 4)
  notes                String?              @db.Text
  providerPayload      Json?
  providerResponse     Json?
  issuedAt             DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  tenant               Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client               Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  issuedBy             User?                @relation("IssuedServiceInvoices", fields: [issuedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([clientId])
  @@index([status])
  @@index([providerExternalId])
}
